<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="presentation.controllers.PortfolioController"
            prefHeight="600.0" prefWidth="900.0">
    <top>
        <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-background-color: #e0e0e0;">
            <padding>
                <Insets top="10" right="15" bottom="10" left="15"/>
            </padding>
            <Button text="Back to Market" onAction="#onBack" prefHeight="30"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label text="Liquidity: ">
                <font><Font size="14.0"/></font>
            </Label>
            <Label fx:id="liquidityLabel" text="--">
                <font><Font name="System Bold" size="14.0"/></font>
            </Label>
        </HBox>
    </top>
    <center>
        <VBox spacing="10">
            <padding>
                <Insets top="10" left="15" right="15"/>
            </padding>
            <Label text="My Holdings">
                <font><Font size="18.0"/></font>
            </Label>
            <TableView fx:id="holdingsTable">
                <columns>
                    <TableColumn fx:id="symbolColumn" text="Symbol" prefWidth="150"/>
                    <TableColumn fx:id="quantityColumn" text="Quantity" prefWidth="100"/>
                    <TableColumn fx:id="priceColumn" text="Current Price" prefWidth="150"/>
                    <TableColumn fx:id="valueColumn" text="Holding Value" prefWidth="150"/>
                    <TableColumn fx:id="stateColumn" text="State" prefWidth="150"/>
                </columns>
            </TableView>
            <HBox spacing="15" alignment="CENTER_LEFT">
                <Label text="Sell Quantity:"/>
                <Spinner fx:id="sellQuantitySpinner" prefWidth="120" editable="true"/>
                <Button fx:id="sellButton" text="Sell Selected" onAction="#onSell" prefWidth="140" prefHeight="30"/>
            </HBox>
            <Label fx:id="statusLabel" textFill="RED"/>
        </VBox>
    </center>
    <bottom>
        <VBox spacing="5">
            <padding>
                <Insets top="10" right="15" bottom="15" left="15"/>
            </padding>
            <HBox spacing="30">
                <Label text="Total Portfolio Value: "/>
                <Label fx:id="totalValueLabel" text="--">
                    <font><Font name="System Bold" size="14.0"/></font>
                </Label>
                <Label text="Net Profit/Loss: "/>
                <Label fx:id="profitLossLabel" text="--">
                    <font><Font name="System Bold" size="14.0"/></font>
                </Label>
            </HBox>
        </VBox>
    </bottom>
</BorderPane>

